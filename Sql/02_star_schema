-- GRAIN VALIDATION CHECK

SELECT COUNT (*) - COUNT (DISTINCT CONCAT(date_key, store_id, product_id)) AS duplicate_records
FROM fact_inventory_sales_daily
;

-- FOREIGN KEY CHECKS

SELECT COUNT(*)
FROM fact_inventory_sales_daily f
LEFT JOIN dim_date d 
ON f.date_key = d.date_key
WHERE d.date_key IS NULL

SELECT COUNT(*)
FROM fact_inventory_sales_daily f
LEFT JOIN dim_store s 
ON f.store_id = s.store_id
WHERE s.store_id IS NULL

SELECT COUNT(*)
FROM fact_inventory_sales_daily f
LEFT JOIN dim_product p 
ON f.product_id = p.product_id
WHERE p.product_id IS NULL

